# SalesBoost marketing site (root) — clean URLs
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let real files and directories pass through
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Privacy policy (extensionless)
  RewriteRule ^privacy/?$ privacy.php [L,QSA]
</IfModule>
