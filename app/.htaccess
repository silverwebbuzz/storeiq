# SWB StoreIQ â€” Apache rewrite rules.
# RewriteBase must match the URL path the app is mounted at.
# If app is at https://storeiq.silverwebbuzz.com/app/  â†’ /app/
# If app is at https://storeiq.silverwebbuzz.com/      â†’ /
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /app/

    # Preserve Authorization header for PHP / FastCGI (session token on API calls).
    RewriteCond %{HTTP:Authorization} ^(.+)$
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%1]

    Options -Indexes

    # Strip trailing slashes (except real directories).
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+)/$ $1 [L,R=301,QSA]

    # If a real file or directory exists, serve it directly (assets, *.php direct hits).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Canonical clean URLs: only for GET â€” POST to *.php must NOT 301 (drops body).
    RewriteCond %{REQUEST_METHOD} =GET
    RewriteCond %{THE_REQUEST} \sGET\s/+app/[^\s?]+\.php[\s?] [NC]
    RewriteRule ^(.+)\.php$ $1 [R=301,L,QSA]

    # ---- App root ----
    RewriteRule ^$ index.php [L,QSA]

    # ---- Primary UI (clean URLs; the fallback below also handles these) ----
    RewriteRule ^dashboard$  dashboard.php  [L,QSA]
    RewriteRule ^bulk-edit$  bulk-edit.php  [L,QSA]
    RewriteRule ^campaigns$  campaigns.php  [L,QSA]
    RewriteRule ^hygiene$    hygiene.php    [L,QSA]
    RewriteRule ^templates$  templates.php  [L,QSA]
    RewriteRule ^settings$   settings.php   [L,QSA]
    RewriteRule ^activity$   activity.php   [L,QSA]

    # ---- Auth ----
    RewriteRule ^auth/install$  auth/install.php  [L,QSA]
    RewriteRule ^auth/callback$ auth/callback.php [L,QSA]

    # ---- Billing ----
    RewriteRule ^billing/subscribe$ billing/subscribe.php [L,QSA]
    RewriteRule ^billing/confirm$   billing/confirm.php   [L,QSA]

    # ---- Webhooks ----
    RewriteRule ^webhooks/handler$                 webhooks/handler.php                 [L,QSA]
    RewriteRule ^webhooks/app_uninstalled$         webhooks/app_uninstalled.php         [L,QSA]
    RewriteRule ^webhooks/products_update$         webhooks/products_update.php         [L,QSA]
    RewriteRule ^webhooks/customers_data_request$  webhooks/customers_data_request.php  [L,QSA]
    RewriteRule ^webhooks/customers_redact$        webhooks/customers_redact.php        [L,QSA]
    RewriteRule ^webhooks/shop_redact$             webhooks/shop_redact.php             [L,QSA]

    # ---- Jobs / cron (web entry with key) ----
    RewriteRule ^jobs/process_webhooks$  jobs/process_webhooks.php  [L,QSA]
    RewriteRule ^jobs/register_webhooks$ jobs/register_webhooks.php [L,QSA]

    # ---- API (clean URLs) ----
    RewriteRule ^api/dashboard$            api/dashboard.php             [L,QSA]
    RewriteRule ^api/bulk-edit/preview$    api/bulk-edit/preview.php     [L,QSA]
    RewriteRule ^api/bulk-edit/create$     api/bulk-edit/create.php      [L,QSA]
    RewriteRule ^api/bulk-edit/list$       api/bulk-edit/list.php        [L,QSA]
    RewriteRule ^api/bulk-edit/detail$     api/bulk-edit/detail.php      [L,QSA]
    RewriteRule ^api/bulk-edit/undo$       api/bulk-edit/undo.php        [L,QSA]
    RewriteRule ^api/bulk-edit/templates$  api/bulk-edit/templates.php   [L,QSA]
    RewriteRule ^api/campaigns/templates$  api/campaigns/templates.php   [L,QSA]
    RewriteRule ^api/campaigns/list$       api/campaigns/list.php        [L,QSA]
    RewriteRule ^api/campaigns/create$     api/campaigns/create.php      [L,QSA]
    RewriteRule ^api/campaigns/cancel$     api/campaigns/cancel.php      [L,QSA]
    RewriteRule ^api/campaigns/detail$     api/campaigns/detail.php      [L,QSA]
    RewriteRule ^api/hygiene/scan$         api/hygiene/scan.php          [L,QSA]
    RewriteRule ^api/hygiene/flags$        api/hygiene/flags.php         [L,QSA]
    RewriteRule ^api/hygiene/rules$        api/hygiene/rules.php         [L,QSA]
    RewriteRule ^api/hygiene/dismiss$      api/hygiene/dismiss.php       [L,QSA]
    RewriteRule ^api/hygiene/fix$          api/hygiene/fix.php           [L,QSA]
    RewriteRule ^api/templates/bulk$       api/templates/bulk.php        [L,QSA]
    RewriteRule ^api/templates/campaigns$  api/templates/campaigns.php   [L,QSA]
    RewriteRule ^api/billing/plans$        api/billing/plans.php         [L,QSA]
    RewriteRule ^api/promo/claim$          api/promo/claim.php           [L,QSA]

    # ---- Fallback: any other /path â†’ path.php if file exists (nested routes too) ----
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+)$ $1.php [L,QSA]
</IfModule>

<IfModule mod_setenvif.c>
    SetEnvIfNoCase Authorization "^(.*)$" HTTP_AUTHORIZATION=$1
</IfModule>

<IfModule mod_headers.c>
    Header always set Content-Security-Policy "frame-ancestors https://*.shopify.com https://admin.shopify.com https://*.myshopify.com;"
    Header always unset X-Frame-Options
</IfModule>
